# Copy to .env and update values as needed
# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=aikb

# App
# Optionally override the full DATABASE_URL. If unset, docker-compose will set it from POSTGRES_* values.
#DATABASE_URL=postgresql://postgres:password@postgres:5432/aikb

# Ollama (if running on host and using Docker for web service)
# If Ollama runs on the host, `host.docker.internal` resolves to the host from Docker Desktop.
OLLAMA_URL=http://host.docker.internal:11434/api/generate

# Application secret key (change for production)
SECRET_KEY=supersecretkey
